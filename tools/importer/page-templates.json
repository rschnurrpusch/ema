          "blocks": ["hero-patient"],
          "defaultContent": ["#title-b71b7dca44"]
        },
        {
          "id": "section-4",
          "name": "Resource Cards",
          "selector": [".title:has(#title-27543d93ee)", ".resource-grid-cards"],
          "style": null,
